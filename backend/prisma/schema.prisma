// Prisma Schema for 좋아하면 울리는

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 사용자 테이블
model User {
  id              String    @id @default(uuid())
  tossUserId      String    @unique // 토스 계정 고유 ID
  name            String?            // 토스 로그인에서 받은 사용자 이름 (필수 동의)
  gender          String?            // 성별 (선택 동의) - male/female
  birthday        DateTime?          // 생년월일 (선택 동의)
  instagramId     String?            // 인스타그램 ID (중복 허용 - 실제 인증은 OAuth로)
  maxSlots        Int       @default(2) // 최대 알람 슬롯 수 (기본 2개, 결제로 증가)
  adFree          Boolean   @default(false) // 광고 영구 제거 (30일 체크인 보상)
  pushEnabled     Boolean   @default(false) // 연결 시 푸시 알림 허용 여부
  tossAppEnabled  Boolean   @default(false) // 연결 시 토스 앱 알림 허용 여부
  messagePushEnabled    Boolean @default(false) // 메시지 수신 시 푸시 알림
  messageTossAppEnabled Boolean @default(false) // 메시지 수신 시 토스 앱 알림
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  alarms       Alarm[]    @relation("UserAlarms")      // 내가 등록한 알람들
  matchesAsUser1 Match[]  @relation("MatchUser1")
  matchesAsUser2 Match[]  @relation("MatchUser2")
  feedbacks    Feedback[]                              // 내가 보낸 피드백들
  verificationSessions VerificationSession[]
  aiClone      AiClone?
  cloneViewPurchases CloneViewPurchase[]
}

// 알람 (좋아요) 테이블
model Alarm {
  id                 String    @id @default(uuid())
  userId             String                          // 알람을 등록한 사용자
  fromInstagramId    String                          // 본인 인스타그램 ID (알람별로 다를 수 있음)
  targetInstagramId  String                          // 대상의 인스타그램 ID
  status             String    @default("waiting")   // waiting | matched
  message            String?                         // 알람 등록 시 남기는 메시지 (선택)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?                       // Soft Delete용 (null = 활성, 값 있으면 = 삭제됨)

  // Relations
  user               User              @relation("UserAlarms", fields: [userId], references: [id], onDelete: Cascade)
  reactions          MessageReaction[]

  @@unique([userId, targetInstagramId]) // 같은 대상에게 중복 알람 방지
}

// 메시지 반응 테이블 (받은 메시지에 이모지 반응)
model MessageReaction {
  id        String   @id @default(uuid())
  alarmId   String   @unique          // 메시지당 1개 반응 (upsert)
  emoji     String                    // ❤️ 😊 🤔 😳 🥹
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alarm     Alarm    @relation(fields: [alarmId], references: [id], onDelete: Cascade)
}

// 매칭 테이블
model Match {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  matchedAt DateTime @default(now())

  // Relations
  user1     User     @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User     @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id]) // 같은 매칭 중복 방지
}

// 피드백 테이블
model Feedback {
  id        String   @id @default(uuid())
  userId    String?                         // 로그인한 사용자 ID (비로그인 시 null)
  category  String                          // 카테고리: 건의, 버그, 신고, 칭찬, 기타
  content   String                          // 피드백 내용
  status    String   @default("pending")    // pending | reviewed | resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// 애널리틱스 이벤트
model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String   // screen | click | impression
  name      String   // alarm_list_screen, alarm_add_button_click 등
  params    Json?
  userId    String?
  sessionId String?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

// Instagram DM 인증 세션
model VerificationSession {
  id                String   @id @default(cuid())
  userId            String
  instagramUsername String
  igUserId          String?
  code              String?
  status            String   @default("pending") // pending | code_sent | verified | expired
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([instagramUsername, status])
  @@index([userId, status])
}

// AI 클론 테이블
model AiClone {
  id              String   @id @default(uuid())
  userId          String   @unique
  instagramId     String
  personalityData Json?    // Big Five 점수, 언어 패턴, 감정 역학 분석 결과
  clonePrompt     String?  @db.Text // LLM 시스템 프롬프트 (클론 페르소나)
  allowMatching   Boolean  @default(false) // 다른 사용자와의 AI 대화 허용
  gender          String?  // male / female / other
  interestedIn    String?  // male / female / all
  status          String   @default("active") // active / paused / deleted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationsAsClone1 AiConversation[] @relation("ConversationClone1")
  conversationsAsClone2 AiConversation[] @relation("ConversationClone2")

  @@index([allowMatching, status])
  @@index([instagramId])
}

// AI 클론 대화 시뮬레이션 테이블
model AiConversation {
  id              String    @id @default(uuid())
  clone1Id        String
  clone2Id        String
  messages        Json      @default("[]") // [{role, content, timestamp}, ...]
  chemistryScore  Float?    // 케미 점수 (0~100)
  summary         String?   @db.Text
  status          String    @default("pending") // pending / in_progress / completed / failed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  clone1          AiClone   @relation("ConversationClone1", fields: [clone1Id], references: [id], onDelete: Cascade)
  clone2          AiClone   @relation("ConversationClone2", fields: [clone2Id], references: [id], onDelete: Cascade)
  purchases       CloneViewPurchase[]

  @@unique([clone1Id, clone2Id])
  @@index([status])
}

// AI 클론 대화 조회 구매 테이블
model CloneViewPurchase {
  id              String   @id @default(uuid())
  userId          String
  conversationId  String
  amount          Int      // 결제 금액 (원)
  purchaseType    String   // conversation_view / alarm_preview
  purchasedAt     DateTime @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
}

