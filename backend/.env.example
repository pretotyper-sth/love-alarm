# Meta Instagram Webhook (developers.facebook.com → 3. Webhooks 구성)
# 「인증 토큰」= 직접 정한 비밀 문자열. 아래 값을 대시보드에 그대로 입력할 것.
# ※ 「토큰 생성」으로 받는 IGAA... 액세스 토큰과는 다름
META_VERIFY_TOKEN=

# 이용 사례 → 「토큰 생성」버튼으로 받은 액세스 토큰 (Graph API / DM 발송)
INSTAGRAM_ACCESS_TOKEN=

# Instagram 개발자 이용 사례에 등록된 비즈니스 계정 ID (숫자)
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Webhook 수신 바디 전체 로그 (디버그 시만 1)
# INSTAGRAM_WEBHOOK_DEBUG=1
